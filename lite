#!/usr/bin/env php
<?php

define('APP_BASE_PATH', __DIR__);
define('BASE_PATH', __DIR__);
require_once __DIR__ . '/vendor/autoload.php';

spl_autoload_register(function (string $class): void {
    $prefix  = 'App\\';
    $baseDir = __DIR__ . '/app/';
    $len     = strlen($prefix);
    if (strncmp($prefix, $class, $len) !== 0) return;
    $file = $baseDir . str_replace('\\', DIRECTORY_SEPARATOR, substr($class, $len)) . '.php';
    if (file_exists($file)) require_once $file;
});

Core\Config\Env::load(__DIR__ . '/.env');
Core\Config\Config::load(
    __DIR__ . '/vendor/litephp/core/Core/Config/defaults',
    __DIR__ . '/config'
);

$app = require __DIR__ . '/vendor/litephp/core/Core/Bootstrap/container.php';
$GLOBALS['container'] = $app;  // keep for any legacy code that reads this
app($app);                      // ← THIS is what was missing

$kernel = new Core\Console\Kernel();
$kernel->handle($argv);